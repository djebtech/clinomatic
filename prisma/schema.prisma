generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// CORE ENTITIES
// ============================================

model Clinic {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  logo            String?
  phone           String
  email           String?
  address         String?
  city            String?

  workingHours    Json      @default("{}")
  holidays        DateTime[]

  subscriptionPlan String   @default("BASIC")
  monthlyFee      Int       @default(12000)
  isActive        Boolean   @default(true)

  // Public booking page
  bookingPageEnabled        Boolean  @default(true)
  bookingPageCustomization  Json?

  // Billing / subscription
  subscriptionStartDate DateTime?
  nextBillingDate       DateTime?
  suspendedAt           DateTime?
  cancelledAt           DateTime?
  cancellationReason    String?
  balance               Int       @default(0)   // positive = credit, negative = owes
  paymentMethod         String?                  // "bank_transfer" | "ccp" | "baridimob" | "cash"

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  users               User[]
  patients            Patient[]
  services            Service[]
  appointments        Appointment[]
  doctors             Doctor[]
  whatsappConfig      WhatsAppConfig?
  socialIntegrations  SocialIntegration[]
  dailyStats          DailyStats[]
  agentAssignments    ClinicAgent[]
  bookingPageVisits   BookingPageVisit[]
  invoices            Invoice[]
  payments            Payment[]
  subscriptionNotes   SubscriptionNote[]
}

model User {
  id             String    @id @default(cuid())
  clinicId       String?
  name           String
  phone          String    @unique
  email          String?   @unique
  emailVerified  Boolean   @default(false)
  password       String?
  role           Role      @default(CLINIC_STAFF)
  isActive       Boolean   @default(true)
  lastActive     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt

  clinic      Clinic?   @relation(fields: [clinicId], references: [id])
  confirmedAppointments Appointment[] @relation("ConfirmedBy")
  performance AgentPerformance?
  sessions    Session[]
  accounts    Account[]
  patientNotes PatientNote[]
  uploadedFiles PatientFile[] @relation("UploadedFiles")
  appointmentTimeline AppointmentTimeline[]
  agentClinics        ClinicAgent[]         @relation("AgentClinics")
  assignedByMe        ClinicAgent[]         @relation("AssignedBy")
  scheduledCallbacks  ScheduledCallback[]
  recordedPayments    Payment[]             @relation("RecordedBy")
  subscriptionNotes   SubscriptionNote[]

  dailyTarget    Int?      @default(30)
  workingHoursAgent Json?
  employmentType String?
  startDate      DateTime? @db.Date

  // Notifications & permissions
  notificationPreferences Json?
  permissions             Json?
  avatar                  String?
  jobTitle                String?
  department              String?
  timezone                String?   @default("Africa/Algiers")
  invitedBy               String?   // ID of user who invited them
  invitedAt               DateTime?

  notifications       Notification[]
  activityLogs        ActivityLog[]
  invitationsReceived InvitationToken[] @relation("InvitedUser")
  invitationsSent     InvitationToken[] @relation("InviterOf")

  @@index([clinicId])
  @@index([role])
}

enum Role {
  SUPER_ADMIN
  CONFIRMATION_AGENT
  CLINIC_OWNER
  CLINIC_STAFF
  DOCTOR
}

model Patient {
  id              String    @id @default(cuid())
  clinicId        String
  name            String
  phone           String
  email           String?
  dateOfBirth     DateTime?
  gender          String?
  address         String?
  city            String?
  notes           String?   @db.Text

  phoneHash       String    @unique
  globalRiskScore Float     @default(0)
  tags            String[]
  source          String?

  // Medical info
  bloodType            String?
  allergies            String?  @db.Text
  chronicConditions    String?  @db.Text
  currentMedications   String?  @db.Text
  emergencyContactName  String?
  emergencyContactPhone String?

  // Consent
  consentSMS       Boolean   @default(true)
  consentWhatsApp  Boolean   @default(true)
  consentMarketing Boolean   @default(false)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastVisit       DateTime?

  clinic           Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments     Appointment[]
  whatsappMessages WhatsAppMessage[]
  notes_list       PatientNote[]
  files            PatientFile[]

  @@unique([clinicId, phone])
  @@index([phoneHash])
  @@index([clinicId])
}

model PatientNote {
  id        String   @id @default(cuid())
  patientId String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())

  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])

  @@index([patientId])
}

model PatientFile {
  id         String   @id @default(cuid())
  patientId  String
  fileName   String
  fileUrl    String
  fileType   String
  fileSize   Int?
  uploadedBy String
  uploadedAt DateTime @default(now())

  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  uploader   User     @relation("UploadedFiles", fields: [uploadedBy], references: [id])

  @@index([patientId])
}

model Doctor {
  id          String   @id @default(cuid())
  clinicId    String
  name        String
  specialty   String?
  phone       String?
  schedule    Json     @default("{}")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([clinicId])
}

model Service {
  id          String   @id @default(cuid())
  clinicId    String
  name        String
  nameAr      String?
  price       Int
  duration    Int
  description String?  @db.Text
  color       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([clinicId])
}

// ============================================
// APPOINTMENT SYSTEM
// ============================================

model Appointment {
  id              String    @id @default(cuid())
  clinicId        String
  patientId       String
  doctorId        String?
  serviceId       String

  date            DateTime
  duration        Int

  status          AppointmentStatus @default(PENDING)
  source          String
  sourceMessageId String?

  confirmedBy     String?
  confirmedAt     DateTime?
  confirmMethod   String?
  confirmNotes    String?   @db.Text
  confirmAttempts Int       @default(0)

  attended        Boolean   @default(false)
  attendedAt      DateTime?
  noShowReason    String?

  price           Int
  paid            Boolean   @default(false)
  paidAt          DateTime?
  paymentMethod   String?

  riskScore       Float?
  remindersSent   Int       @default(0)
  notes           String?   @db.Text
  sourceUrl       String?
  deviceType      String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  clinic           Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient          Patient   @relation(fields: [patientId], references: [id])
  doctor           Doctor?   @relation(fields: [doctorId], references: [id])
  service          Service   @relation(fields: [serviceId], references: [id])
  confirmer        User?     @relation("ConfirmedBy", fields: [confirmedBy], references: [id])
  whatsappMessages  WhatsAppMessage[]
  timeline          AppointmentTimeline[]
  callbacks         ScheduledCallback[]

  @@index([clinicId, date])
  @@index([status])
  @@index([patientId])
  @@index([confirmedBy])
}

model AppointmentTimeline {
  id            String   @id @default(cuid())
  appointmentId String
  userId        String?
  action        String
  details       Json?
  createdAt     DateTime @default(now())

  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  user          User?       @relation(fields: [userId], references: [id])

  @@index([appointmentId])
}

enum AppointmentStatus {
  PENDING
  CONFIRMING
  CONFIRMED
  ATTENDED
  NO_SHOW
  CANCELLED
  RESCHEDULED
}

// ============================================
// WHATSAPP AUTOMATION
// ============================================

model WhatsAppConfig {
  id              String   @id @default(cuid())
  clinicId        String   @unique
  phoneNumber     String
  apiToken        String?
  apiUrl          String?
  isConnected     Boolean  @default(false)
  instanceName    String?

  autoConfirm     Boolean  @default(true)
  autoReminder24h Boolean  @default(true)
  autoReminder2h  Boolean  @default(true)
  autoFollowUp    Boolean  @default(true)
  autoNoShowRecovery Boolean @default(false)
  autoRecall      Boolean  @default(false)
  recallDays      Int      @default(180)

  confirmTemplate        String? @db.Text
  reminder24hTemplate    String? @db.Text
  reminder2hTemplate     String? @db.Text
  followUpTemplate       String? @db.Text
  noShowRecoveryTemplate String? @db.Text
  recallTemplate         String? @db.Text

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clinic          Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
}

model WhatsAppMessage {
  id              String    @id @default(cuid())
  clinicId        String
  patientId       String
  appointmentId   String?

  direction       Direction
  messageType     MessageType
  content         String    @db.Text
  status          MessageStatus

  externalId      String?
  scheduledFor    DateTime?
  sentAt          DateTime  @default(now())
  deliveredAt     DateTime?
  readAt          DateTime?
  repliedAt       DateTime?
  errorMessage    String?   @db.Text

  patient         Patient      @relation(fields: [patientId], references: [id])
  appointment     Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([appointmentId])
  @@index([patientId])
  @@index([sentAt])
  @@index([externalId])
  @@index([scheduledFor])
  @@index([status])
}

enum Direction {
  OUTBOUND
  INBOUND
}

enum MessageType {
  CONFIRMATION
  REMINDER_24H
  REMINDER_2H
  FOLLOW_UP
  RECALL
  NO_SHOW_RECOVERY
  MANUAL
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  REPLIED
  FAILED
}

// ============================================
// SOCIAL MEDIA INTEGRATIONS
// ============================================

model SocialIntegration {
  id          String    @id @default(cuid())
  clinicId    String
  platform    Platform
  accountId   String
  accountName String?
  accessToken String    @db.Text
  isActive    Boolean   @default(true)
  lastSync    DateTime?
  createdAt   DateTime  @default(now())

  clinic      Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, platform])
}

enum Platform {
  INSTAGRAM
  FACEBOOK
  WHATSAPP
}

// ============================================
// PUBLIC BOOKING PAGE
// ============================================

model BookingPageVisit {
  id                  String    @id @default(cuid())
  clinicId            String
  ipAddress           String?
  userAgent           String?
  referrer            String?
  visitedAt           DateTime  @default(now())
  convertedToBooking  Boolean   @default(false)
  appointmentId       String?

  clinic              Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([visitedAt])
}

// ============================================
// ANALYTICS
// ============================================

model DailyStats {
  id                  String   @id @default(cuid())
  clinicId            String
  date                DateTime @db.Date

  totalBookings       Int      @default(0)
  confirmedBookings   Int      @default(0)
  attendedBookings    Int      @default(0)
  noShows             Int      @default(0)
  cancelled           Int      @default(0)

  revenue             Int      @default(0)
  lostRevenue         Int      @default(0)

  newPatients         Int      @default(0)
  returningPatients   Int      @default(0)

  instagramBookings   Int      @default(0)
  facebookBookings    Int      @default(0)
  whatsappBookings    Int      @default(0)
  phoneBookings       Int      @default(0)
  walkInBookings      Int      @default(0)

  createdAt           DateTime @default(now())

  clinic              Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, date])
  @@index([date])
}

model AgentPerformance {
  id                  String   @id @default(cuid())
  userId              String   @unique

  totalConfirmed      Int      @default(0)
  totalCalls          Int      @default(0)
  totalWhatsApp       Int      @default(0)
  confirmationRate    Float    @default(0)

  weekConfirmed       Int      @default(0)
  weekCalls           Int      @default(0)
  avgConfirmTime      Float?
  currentStreak       Int      @default(0)
  bestStreak          Int      @default(0)
  totalWhatsAppSent   Int      @default(0)
  totalSMSSent        Int      @default(0)

  weekStart           DateTime
  updatedAt           DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// CONFIRMATION TEAM MANAGEMENT
// ============================================

model ClinicAgent {
  id         String   @id @default(cuid())
  clinicId   String
  agentId    String
  assignedAt DateTime @default(now())
  assignedBy String?

  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  agent      User     @relation("AgentClinics", fields: [agentId], references: [id], onDelete: Cascade)
  assigner   User?    @relation("AssignedBy", fields: [assignedBy], references: [id])

  @@unique([clinicId, agentId])
  @@index([clinicId])
  @@index([agentId])
}

model ScheduledCallback {
  id            String   @id @default(cuid())
  appointmentId String
  agentId       String
  scheduledFor  DateTime
  notes         String?  @db.Text
  completed     Boolean  @default(false)
  createdAt     DateTime @default(now())

  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  agent         User        @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([agentId])
  @@index([scheduledFor])
}

// ============================================
// BETTER AUTH TABLES
// ============================================

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

// ============================================
// BILLING & SUBSCRIPTION MANAGEMENT
// ============================================

enum InvoiceStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id            String        @id @default(cuid())
  clinicId      String
  invoiceNumber String        @unique
  date          DateTime      @default(now())
  dueDate       DateTime
  amount        Int           // total in DA
  discountAmount Int          @default(0)
  currency      String        @default("DZD")
  status        InvoiceStatus @default(UNPAID)
  period        String?       // "Mai 2026"
  lineItems     Json?         // [{description, quantity, unitPrice, total}]
  notes         String?       @db.Text
  pdfUrl        String?
  sentAt        DateTime?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())

  clinic        Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  payments      Payment[]
  reminders     PaymentReminder[]

  @@index([clinicId])
  @@index([status])
  @@index([dueDate])
}

model Payment {
  id                   String   @id @default(cuid())
  clinicId             String
  invoiceId            String?
  amount               Int
  currency             String   @default("DZD")
  paymentDate          DateTime
  paymentMethod        String   // bank_transfer | ccp | baridimob | cash | card
  transactionReference String?
  payerName            String?
  notes                String?  @db.Text
  receiptUrl           String?
  recordedBy           String?
  createdAt            DateTime @default(now())

  clinic               Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  invoice              Invoice? @relation(fields: [invoiceId], references: [id])
  recorder             User?    @relation("RecordedBy", fields: [recordedBy], references: [id])

  @@index([clinicId])
  @@index([invoiceId])
}

model PaymentReminder {
  id        String   @id @default(cuid())
  invoiceId String
  type      String   // before_5d | due_today | overdue_7d | overdue_14d | overdue_30d | overdue_45d
  sentAt    DateTime @default(now())
  method    String?  // email | whatsapp | both

  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model SubscriptionNote {
  id        String   @id @default(cuid())
  clinicId  String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())

  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])

  @@index([clinicId])
}

model PlanChangeLog {
  id          String   @id @default(cuid())
  clinicId    String
  fromPlan    String
  toPlan      String
  fromFee     Int
  toFee       Int
  changedBy   String?
  reason      String?
  effectiveAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([clinicId])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String    // APPOINTMENT_CREATED | PAYMENT_RECEIVED | WHATSAPP_DISCONNECTED | etc.
  title     String
  message   String    @db.Text
  data      Json?     // { appointmentId, clinicId, etc. }
  linkUrl   String?   // Deep link to relevant page
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([userId, read])
}

// ============================================
// ACTIVITY LOG
// ============================================

model ActivityLog {
  id         String   @id @default(cuid())
  clinicId   String?
  userId     String?
  action     String   // APPOINTMENT_CREATED | USER_LOGIN | PAYMENT_RECORDED | etc.
  targetType String?  // "appointment" | "patient" | "invoice" | "user"
  targetId   String?
  targetName String?
  details    Json?    // before/after or extra context
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([clinicId])
  @@index([action])
  @@index([createdAt])
  @@index([targetType, targetId])
}

// ============================================
// TEAM INVITATIONS
// ============================================

model InvitationToken {
  id          String    @id @default(cuid())
  token       String    @unique
  email       String
  userId      String    // The newly created (INVITED) user
  invitedBy   String    // The user who sent the invite
  clinicId    String?
  role        String    @default("CLINIC_STAFF")
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  user        User      @relation("InvitedUser", fields: [userId], references: [id], onDelete: Cascade)
  inviter     User      @relation("InviterOf", fields: [invitedBy], references: [id])

  @@index([token])
  @@index([email])
  @@index([userId])
}
